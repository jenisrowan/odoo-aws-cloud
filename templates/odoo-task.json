[
  {
    "name": "odoo",
    "image": "${odoo_image_url}",
    "cpu": 896,
    "memory": 3456,
    "essential": true,
    "environment": [
      {
        "name": "HOST",
        "value": "${db_host}"
      },
      {
        "name": "USER",
        "value": "odoo"
      },
      {
        "name": "PASSWORD",
        "value": "${db_password}"
      }
    ],
    "mountPoints": [
      {
        "sourceVolume": "odoo-efs",
        "containerPath": "/var/lib/odoo"
      }
    ]
  },
  {
    "name": "nginx",
    "image": "${nginx_image_url}",
    "cpu": 128,
    "memory": 128,
    "essential": true,
    "portMappings": [
      {
        "containerPort": 80,
        "hostPort": 80
      }
    ]
  }
]
