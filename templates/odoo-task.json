[
  {
    "name": "odoo",
    "image": "${odoo_image_url}",
    "cpu": 1536,
    "memory": 6912,
    "essential": true,
    "environment": [
      {
        "name": "HOST",
        "value": "${db_host}"
      },
      {
        "name": "USER",
        "value": "odoo"
      }
    ],
    "secrets": [
      {
        "name": "PASSWORD",
        "valueFrom": "${db_password_arn}:password::"
      },
      {
        "name": "ODOO_ADMIN_PASSWD",
        "valueFrom": "${admin_password_arn}:password::"
      }
    ],
    "mountPoints": [
      {
        "sourceVolume": "odoo-efs",
        "containerPath": "/var/lib/odoo"
      }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/odoo",
        "awslogs-region": "${aws_region}",
        "awslogs-stream-prefix": "odoo"
      }
    }
  },
  {
    "name": "nginx",
    "image": "${nginx_image_url}",
    "cpu": 128,
    "memory": 128,
    "essential": true,
    "portMappings": [
      {
        "containerPort": 80,
        "hostPort": 80
      }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/odoo",
        "awslogs-region": "${aws_region}",
        "awslogs-stream-prefix": "nginx"
      }
    }
  }
]
