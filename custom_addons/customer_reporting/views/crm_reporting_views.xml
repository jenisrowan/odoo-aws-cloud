<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_customer_reporting_form" model="ir.ui.view">
        <field name="name">customer.reporting.form</field>
        <field name="model">customer.reporting</field>
        <field name="arch" type="xml">
            <form string="Customer Reporting">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Company Name" />
                        <h1>
                            <field name="name" placeholder="e.g. Acme Corporation" />
                        </h1>
                    </div>
                    
                    <group name="main_group">
                        <group string="Analysis Action">
                            <label for="action_get_report" string="Generate Report" />
                            <div class="o_row">
                                <button name="action_get_report" string="Run AI Search" type="object" class="oe_highlight" icon="fa-magic" />
                                <span class="text-muted italic"> (Takes approx. 5 mins)</span>
                            </div>
                        </group>
                    </group>

                    <div class="mt-4 mb-4" />

                    <separator string="Final Result" />
                    <group>
                        <group>
                            <field name="report_file" filename="report_filename" widget="binary" string="Download Report" />
                            <field name="report_filename" invisible="1" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_customer_reporting_tree" model="ir.ui.view">
        <field name="name">customer.reporting.tree</field>
        <field name="model">customer.reporting</field>
        <field name="arch" type="xml">
            <list string="Customer Reporting">
                <field name="name" />
                <field name="report_filename" />
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_customer_reporting" model="ir.actions.act_window">
        <field name="name">Customer Reporting</field>
        <field name="res_model">customer.reporting</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item -->
    <!-- Adds to the CRM application's existing reporting menu -->
    <menuitem id="menu_customer_reporting"
        name="Customer Reporting"
        parent="crm.crm_menu_report"
        action="action_customer_reporting"
        sequence="20" />
</odoo>
